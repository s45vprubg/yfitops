# yfitops V2 — environment template.
# Copy to deploy/.env (gitignored) and fill in. Every var maps to a field read
# by server/internal/config/config.go. Defaults below are dev-safe; the server
# boots with all of them at the listed values even if .env is absent.
#
#   cp deploy/.env.example deploy/.env

# ----------------------------------------------------------------------------
# SECURITY — change these before any non-local deployment.
# ----------------------------------------------------------------------------
# Gates the admin / Control Room (design_doc §9). The admin client must present
# this secret. CHANGE IT — the default is a placeholder.
ADMIN_SECRET=changeme-admin

# HMAC key for the anti-cheat nonce gate (§4D). Any long random string.
YFI_NONCE_SECRET=dev-nonce-secret

# HMAC key signing the rotating QR join tokens (§3.1). Any long random string.
YFI_JOIN_SECRET=dev-join-secret

# ----------------------------------------------------------------------------
# SPOTIFY — REQUIRED for real audio playback.
# Get these from https://developer.spotify.com/dashboard (create an app).
# Requires a Spotify PREMIUM account on the stage device. Without these the
# server still runs, but track playback is mocked/disabled (no real audio).
# The redirect URI below MUST be added verbatim to your Spotify app's allowlist.
# ----------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8777/auth/spotify/callback

# ----------------------------------------------------------------------------
# DATA LAYER — defaults point at the compose service names. Override only if
# running the server outside compose. If unreachable at boot, the server falls
# back to in-memory store + a seeded sample board (see cmd/gameserver/main.go).
# ----------------------------------------------------------------------------
YFI_REDIS_ADDR=redis:6379
YFI_POSTGRES_DSN=postgres://yfitops:yfitops@postgres:5432/yfitops?sslmode=disable

# ----------------------------------------------------------------------------
# NETWORK / TLS — must match the published compose ports.
# 4433 is UDP (QUIC/HTTP3/WebTransport); 8777 is TCP (health/OAuth/cert-hash).
# Cert files default to /certs/*.pem inside the container; the server
# auto-generates a self-signed pair there on first boot if missing.
# ----------------------------------------------------------------------------
YFI_LISTEN_ADDR=:4433
YFI_HTTP_ADDR=:8777
YFI_CERT_FILE=/certs/cert.pem
YFI_KEY_FILE=/certs/key.pem

# ----------------------------------------------------------------------------
# LYRICS / GAMEPLAY — optional tuning.
# ----------------------------------------------------------------------------
# LRCLIB synced-lyrics source (§6). Public instance by default.
YFI_LRCLIB_URL=https://lrclib.net

# Skip-vote threshold percent of active users, 50-100 (§3.8).
YFI_SKIP_THRESHOLD=50

# Logical game session id used for persistence keys.
YFI_SESSION_ID=session

# Board dimensions (default 5x5 Jeopardy grid). Read by config.go.
YFI_BOARD_ROWS=5
YFI_BOARD_COLS=5
