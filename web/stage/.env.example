# yfitops Stage — environment overrides (all optional; sensible <host> defaults).
# Copy to .env.local and edit as needed.

# WebTransport endpoint (role "stage" connects here)
VITE_WT_URL=https://localhost:4433/wt

# Plain-HTTP backend: serves /cert-hash (dev cert pinning) and /auth/spotify (OAuth)
VITE_HTTP_URL=http://localhost:8777

# Mobile buzzer join URL encoded into the QR codes
VITE_JOIN_URL=http://localhost:5173
